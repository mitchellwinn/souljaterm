{
  "name": "souljaterm",
  "version": "0.1.6",
  "description": "A custom terminal for vibing in Claude Code",
  "author": {
    "name": "mitchellwinn",
    "email": "mitchellswinn@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchellwinn/souljaterm.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "install-hooks": "node tools/install-hooks.js",
    "uninstall-hooks": "node tools/install-hooks.js uninstall",
    "postinstall": "electron-rebuild -f -w node-pty",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.souljaterm.app",
    "productName": "souljaterm",
    "afterPack": "build/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "mitchellwinn",
        "repo": "souljaterm",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "bin/**/*",
      "assets/icon.icns",
      "assets/icon.png",
      "assets/roll/frames/**/*",
      "assets/roll/voice/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "bin/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0"
  }
}
